# Database connection — provided automatically when you create a Vercel
# Postgres (Neon) database from the project's Storage tab. You normally do
# NOT set these by hand; Vercel injects them. Listed here for reference:
#   POSTGRES_URL=...
#   POSTGRES_URL_NON_POOLING=...

# Optional shared access key (recommended). When APP_ACCESS_KEY is set on the
# server, the /api/store endpoint rejects requests that don't send the matching
# key, keeping casual visitors out of your data. Set BOTH to the same value:
#   - APP_ACCESS_KEY        (server, no VITE_ prefix)
#   - VITE_APP_ACCESS_KEY   (baked into the frontend at build time)
# Use a long random string, e.g. the output of: openssl rand -hex 24
# APP_ACCESS_KEY=
# VITE_APP_ACCESS_KEY=
